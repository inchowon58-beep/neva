# Gemini API (Google AI Studio에서 발급)

GEMINI_API_KEY=your_gemini_api_key_here



# 관리자 계정

ADMIN_USERNAME=your_admin_username

ADMIN_PASSWORD=your_admin_password



# 세션 암호화 키 (32자 이상 랜덤 문자열 권장)

ADMIN_SESSION_SECRET=change-this-to-a-long-random-secret-string



# 사이트 URL (SEO sitemap/robots용)

NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app



# Vercel Blob (Vercel 배포 시 Storage > Blob 생성 후 자동 설정)

BLOB_READ_WRITE_TOKEN=



# ── 분양 상담 알림 (Discord 웹훅 · 무료) ──

# Discord 서버 → 채널 설정 → 연동 → 웹후크 → 새 웹후크 → URL 복사

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/xxxxxxxx

